# ── Copy to .env and fill in production values ────────────────────────────────

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/analytics_db
DATABASE_USER=analytics
DATABASE_PASSWORD=analytics_secret

# JWT — CHANGE THIS in production! Use: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-256-bits-long
JWT_EXPIRATION_MS=86400000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Render deploy hook (optional — set in GitHub Actions secrets)
RENDER_DEPLOY_HOOK_URL=
